<div class="song-topbar" id="song-topbar">
  <div class="song-topbar-inner">
    <a class="back-link" href="index.html" aria-label="Zpět na seznam">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="20" y1="12" x2="4" y2="12"></line>
        <polyline points="10 18 4 12 10 6"></polyline>
      </svg>
    </a>    
    
    <div class="topbar-title" id="topbar-title">Načítám…</div>
    
    <div class="topbar-actions">
      <button class="icon-btn" type="button" id="audio-toggle" aria-label="Přehrát">►</button>
      <button class="icon-btn" type="button" onclick="changeSize(-2)" aria-label="Zmenšit písmo">A−</button>
      <button class="icon-btn" type="button" onclick="changeSize(2)" aria-label="Zvětšit písmo">A+</button>
      
      <button class="icon-btn" type="button" id="more-menu-btn" style="font-size: 20px;">⋮</button>

      <div id="more-menu-dropdown" class="more-menu-dropdown">
        <div class="menu-group">
          <span class="menu-label">Transpozice</span>
          <div class="transpose-row">
            <button class="menu-btn" type="button" onclick="changeShift(-1)">♭</button>
            <span class="shift-display-inline" id="shift-display">0</span>
            <button class="menu-btn" type="button" onclick="changeShift(1)">♯</button>
          </div>
        </div>
        
        <hr class="menu-divider">
        
        <button class="menu-link-btn" type="button" id="toggle-chords">
          <span class="menu-icon">C</span> Vypnout/Zapnout akordy
        </button>
        
        <button class="menu-link-btn" type="button" onclick="toggleColumns()">
          <span class="menu-icon">⫿</span> Počet sloupců
        </button>
        
        <button class="menu-link-btn" type="button" onclick="toggleDarkMode()">
          <span class="menu-icon">🌙</span> Tmavý režim
        </button>
      </div>
    </div>
  </div>

  <div class="audio-drawer" id="audio-drawer" aria-label="Audio nahrávky">
    <div class="audio-list" id="audio-list"></div>
    <audio id="audio-player" controls></audio>
  </div>
</div>